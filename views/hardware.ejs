<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechRM - Soluciones de Hardware</title>
    <style>
        :root {
            --bg-dark: #0b0c12;
            --card-bg: #16171f;
            --accent-blue: #93c5fd;
            --text-main: #ffffff;
            --text-muted: #8b8e9f;
            --border-color: rgba(255, 255, 255, 0.1);
            --form-input: #1c1e26;
            --nav-bg: rgba(11, 12, 16, 0.95);
            --nav-border: rgba(255,255,255,0.05);
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Inter', system-ui, sans-serif;
            margin: 0;
            line-height: 1.6;
            min-height: 100vh;
        }

        /* Hero Header */
        .hardware-header {
            text-align: center;
            padding: 6rem 2rem 4rem;
        }

        .hardware-header h1 {
            font-size: 3rem;
            max-width: 800px;
            margin: 0 auto 1.5rem;
            line-height: 1.1;
        }

        .hardware-header h1 span { color: var(--accent-blue); }

        .hardware-header p {
            color: var(--text-muted);
            max-width: 600px;
            margin: 0 auto 2rem;
        }

        .badge-container {
            display: flex;
            justify-content: center;
            gap: 1rem;
        }

        .badge {
            background: #1c1e26;
            border: 1px solid var(--border-color);
            padding: 0.4rem 1rem;
            border-radius: 15px;
            font-size: 0.65rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
        }

        /* Services Grid */
        .container { max-width: 1100px; margin: 0 auto; padding: 2rem; }

        .main-service-card {
            background: var(--card-bg);
            border-radius: 12px;
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            overflow: hidden;
            border: 1px solid var(--border-color);
            margin-bottom: 2rem;
        }

        .service-content { padding: 3rem; }
        .service-image { background: url('https://images.unsplash.com/photo-1587202377425-8369045261ca?auto=format&fit=crop&q=80&w=800') center/cover; }

        .service-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-bottom: 2rem;
        }

        .mini-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 2.5rem;
        }

        .mini-card img {
            width: 100%;
            height: 150px;
            object-fit: cover;
            border-radius: 8px;
            margin: 1.5rem 0;
            filter: grayscale(1) brightness(0.6);
        }

        .btn-service {
            width: 100%;
            padding: 0.8rem;
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-main);
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            cursor: pointer;
        }
        
        .btn-primary-service {
            background: var(--accent-blue);
            color: #1e3a8a;
            border: none;
            width: auto;
            padding: 0.8rem 2rem;
        }

        /* Banner Home TV */
        .tv-banner {
            background: #111218;
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.5rem 2.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 4rem;
        }

        .tv-info h4 { font-size: 0.9rem; margin-bottom: 0.2rem; }
        .tv-info p { font-size: 0.75rem; color: var(--text-muted); }

        /* Form Presupuesto */
        .quote-section {
            background: #111218;
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 4rem;
            text-align: center;
        }

        .steps {
            display: flex;
            justify-content: center;
            gap: 4rem;
            margin: 3rem 0;
        }

        .step-item { color: var(--text-muted); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; }
        .step-num {
            width: 35px; height: 35px;
            background: var(--accent-blue);
            color: #000;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 0.5rem;
            font-weight: 800;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            text-align: left;
            margin-top: 3rem;
        }

        .form-group { margin-bottom: 2rem; }
        .full-width { grid-column: 1 / -1; }

        label {
            display: block;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            margin-bottom: 1rem;
            color: #d1d5db;
        }

        input, select, textarea {
            width: 100%;
            background: transparent;
            border: none;
            border-bottom: 1px solid var(--border-color);
            padding: 0.8rem 0;
            color: white;
            font-family: inherit;
        }

        select { background-color: var(--form-input); padding: 1rem; border-radius: 8px; border: 1px solid var(--border-color); }

        .btn-submit {
            background: var(--accent-blue);
            color: #1e3a8a;
            padding: 1rem 3rem;
            border-radius: 30px;
            border: none;
            font-weight: 800;
            text-transform: uppercase;
            cursor: pointer;
            margin-top: 2rem;
        }

        /* Footer */
        footer {
            padding: 4rem 6%;
            border-top: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            font-size: 0.7rem;
            color: var(--text-muted);
            text-transform: uppercase;
            font-weight: 600;
        }

        .footer-links { display: flex; gap: 2rem; }

        /* Light Mode Styles */
        .light-mode {
            --bg-dark: #ffffff;
            --card-bg: #f8f9fa;
            --accent-blue: #007bff;
            --text-main: #212529;
            --text-muted: #6c757d;
            --border-color: rgba(0, 0, 0, 0.1);
            --form-input: #e9ecef;
            --nav-bg: rgba(248, 249, 250, 0.95);
            --nav-border: rgba(0,0,0,0.05);
        }

        .light-mode nav {
            background: var(--nav-bg);
        }

        .light-mode .nav-links a.active {
            color: #007bff;
            border-bottom: 2px solid #007bff;
        }

        .light-mode .btn-toggle {
            border: 1px solid rgba(0,0,0,0.2);
        }

        .light-mode .btn-toggle:hover {
            background: rgba(0,0,0,0.1);
            border-color: rgba(0,0,0,0.4);
        }

        .light-mode footer {
            border-top: 1px solid rgba(0, 0, 0, 0.1);
        }
    </style>
</head>
<body>

    <%- include('navbar') %>

    <header class="hardware-header">
        <div class="badge-container">
            <span class="badge">Hardware Elite</span>
            <span class="badge">Estándar Industrial</span>
        </div>
        <h1>Soluciones de <span>Hardware</span> de Alto Nivel</h1>
        <p>Ingeniería de precisión para infraestructuras tecnológicas críticas. Fusionamos potencia bruta con diseño meticuloso.</p>
    </header>

    <div class="container">
        <!-- Servicio Principal -->
        <div class="main-service-card">
            <div class="service-content">
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#93c5fd" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                <h2 style="margin: 1.5rem 0;">Montaje de Equipos de Alto Rendimiento</h2>
                <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 2rem;">Diseñamos y ensamblamos PC Gaming de última generación y Estaciones de Trabajo optimizadas para renderizado 3D, IA y flujos de trabajo científicos complejos.</p>
                <button class="btn-service btn-primary-service">SOLICITAR ESTE SERVICIO</button>
            </div>
            <div class="service-image"></div>
        </div>

        <!-- Grid Secundario -->
        <div class="service-grid">
            <div class="mini-card">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#93c5fd" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <h3 style="margin: 1rem 0;">Reparación & Mantenimiento</h3>
                <p style="color: var(--text-muted); font-size: 0.8rem;">Diagnóstico avanzado bajo estándares industriales para garantizar la longevidad de su infraestructura.</p>
                <img src="https://images.unsplash.com/photo-1591488320449-011701bb6704?auto=format&fit=crop&q=80&w=400" alt="Hardware component">
                <button class="btn-service">SOLICITAR ESTE SERVICIO</button>
            </div>
            <div class="mini-card">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#93c5fd" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                <h3 style="margin: 1rem 0;">Asesorías Estratégicas</h3>
                <p style="color: var(--text-muted); font-size: 0.8rem;">Consultoría técnica para la optimización de flujos de trabajo mediante la selección estratégica de hardware.</p>
                <div style="height: 150px; margin: 1.5rem 0;"></div> <!-- Espacio para igualar diseño -->
                <button class="btn-service">SOLICITAR ESTE SERVICIO</button>
            </div>
        </div>

        <!-- Banner TV -->
        <div class="tv-banner">
            <div class="tv-info">
                <h4>Soluciones de Home TV</h4>
                <p>Integración básica de sistemas OLED y audio.</p>
            </div>
            <button class="btn-service" style="width: auto; padding: 0.5rem 1.5rem; font-size: 0.65rem;">SOLICITAR CATÁLOGO →</button>
        </div>

        <!-- Formulario -->
        <section class="quote-section">
            <h2 style="font-size: 2.2rem;">Solicita tu Presupuesto</h2>
            
            <div class="steps">
                <div class="step-item"><div class="step-num">1</div>SERVICIO</div>
                <div class="step-item"><div class="step-num" style="background: #1c1e26; color: var(--text-muted);">2</div>DETALLES</div>
                <div class="step-item"><div class="step-num" style="background: #1c1e26; color: var(--text-muted);">3</div>CONTACTO</div>
            </div>

            <form>
                <div class="form-grid">
                    <div class="form-group full-width">
                        <label>1. Selecciona tu servicio</label>
                        <select>
                            <option>Montaje de Equipos</option>
                            <option>Reparación</option>
                            <option>Asesoría</option>
                        </select>
                    </div>
                    <div class="form-group full-width">
                        <label>2. Cuéntanos tu necesidad</label>
                        <textarea placeholder="Describe brevemente qué necesitas..." rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label>3. Tu Nombre</label>
                        <input type="text" placeholder="Tu nombre completo">
                    </div>
                    <div class="form-group">
                        <label>Correo Electrónico</label>
                        <input type="email" placeholder="ejemplo@mail.com">
                    </div>
                </div>
                <button type="button" class="btn-submit">ENVIAR SOLICITUD AHORA</button>
            </form>
        </section>
    </div>

    <footer>
        <div class="logo">TECHRM</div>
        
        <div>© 2026 TECHRM. ENGINEERED FOR THE FUTURE.</div>
    </footer>

</body>
</html>