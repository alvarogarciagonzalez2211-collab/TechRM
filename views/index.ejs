<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechRM - Soluciones Integrales</title>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .hero-left {
            background: linear-gradient(var(--overlay-start), var(--overlay-end)), url('https://images.unsplash.com/photo-1591488320449-011701bb6704?auto=format&fit=crop&q=80&w=1920') center/cover;
            border-right: 1px solid var(--nav-border);
        }

        .hero-right {
            background: linear-gradient(var(--overlay-start), var(--overlay-end)), url('https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&q=80&w=1920') center/cover;
        }

        .btn-blue {
            background-color: var(--accent-blue);
            color: #1e3a8a;
        }

        .btn-purple {
            background-color: var(--accent-purple);
            color: #4c1d95;
        }

        .light-mode .btn-blue,
        .light-mode .btn-purple {
            color: #ffffff;
        }
    </style>
</head>
<body>

    <%- include('navbar') %>

    <section class="hero">
        <div class="hero-half hero-left">
            <h1>PRECISIÓN EN<br><span class="text-gradient-blue">HARDWARE.</span></h1>
            <p>Soluciones expertas en montaje de estaciones a medida, reparación técnica avanzada, mantenimiento preventivo y asesoría en optimización de infraestructura.</p>
            <button class="hero-btn btn-blue" onclick="window.location.href='/hardware'">EXPLORAR OPCIONES HARDWARE</button>
        </div>
        
        <div class="hero-half hero-right">
            <h1>EXCELENCIA EN<br><span class="text-gradient-purple">SOFTWARE.</span></h1>
            <p>Desarrollo de ecosistemas digitales: CRM/ERP personalizados, TPVs de alto rendimiento, presencia web escalable y modernización de sistemas heredados.</p>
            <button class="hero-btn btn-purple" onclick="window.location.href='/software'">EXPLORAR OPCIONES SOFTWARE</button>
        </div>
    </section>

    <section id="servicios">
        <div class="section-header">
            <div class="section-subtitle">NUESTRA EXPERIENCIA</div>
            <h2 class="section-title">Soluciones Unificadas</h2>
        </div>

        <div class="grid-2">
            <div class="card card-blue">
                <div class="card-header">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#93c5fd" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect>
                        <rect x="9" y="9" width="6" height="6"></rect>
                        <line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line>
                        <line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line>
                        <line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="14" x2="23" y2="14"></line>
                        <line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="14" x2="4" y2="14"></line>
                    </svg>
                    <h3>Hardware & Sistemas</h3>
                </div>
                <div class="inner-items">
                    <a class="inner-card" href="/montaje">
                        <svg class="inner-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
                        <div class="inner-card-content">
                            <h4>Montaje</h4>
                            <p>Estaciones de trabajo a medida.</p>
                        </div>
                    </a>
                    <a class="inner-card" href="/reparacion">
                        <svg class="inner-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                        <div class="inner-card-content">
                            <h4>Reparación y Mantenimiento</h4>
                            <p>Soporte técnico de alto nivel.</p>
                        </div>
                    </a>
                    <div class="inner-card">
                        <svg class="inner-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                        <div class="inner-card-content">
                            <h4>Asesorías</h4>
                            <p>Optimización de infraestructura.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card card-purple">
                <div class="card-header">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#d8b4fe" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line>
                    </svg>
                    <h3>Desarrollo & Software</h3>
                </div>
                <div class="inner-grid">
                    <a class="inner-card" href="/crm">
                        <div class="inner-card-content">
                            <h4>CRM/ERP</h4>
                            <p>Gestión empresarial robusta.</p>
                        </div>
                    </a>
                    <a class="inner-card" href="/sistemas-venta">
                        <div class="inner-card-content">
                            <h4>TPVs</h4>
                            <p>Puntos de venta eficientes.</p>
                        </div>
                    </a>
                    <a class="inner-card" href="/paginas-web">
                        <div class="inner-card-content">
                            <h4>Páginas Web</h4>
                            <p>Presencia digital escalable.</p>
                        </div>
                    </a>
                    <a class="inner-card" href="/automatizaciones">
                        <div class="inner-card-content">
                            <h4>Automatizaciones</h4>
                            <p>Adaptación de software.</p>
                        </div>
                    </a>
                </div>
            </div>
        </div>

        <div class="banner-tv">
            <div class="banner-tv-content">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#c084fc" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="7" width="20" height="15" rx="2" ry="2"></rect><polyline points="17 2 12 7 7 2"></polyline>
                </svg>
                <div class="banner-tv-text">
                    <h3>HOME TV & ENTRETENIMIENTO</h3>
                    <p>Configuración profesional de centros de entretenimiento y sistemas multimedia domésticos.</p>
                </div>
            </div>
            <button class="btn-outline-sm">SABER MÁS SOBRE HOME TV</button>
        </div>
    </section>

    <section id="caracteristicas">
        <div class="features-grid">
            <div class="feature-card">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#93c5fd" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle><path d="M12 2v4"></path><path d="M12 18v4"></path><path d="M4.93 4.93l2.83 2.83"></path><path d="M16.24 16.24l2.83 2.83"></path><path d="M2 12h4"></path><path d="M18 12h4"></path><path d="M4.93 19.07l2.83-2.83"></path><path d="M16.24 7.76l2.83-2.83"></path>
                </svg>
                <h3>Velocidad Pura</h3>
                <p>Latencia cero garantizada en cada línea de código y cada componente.</p>
            </div>
            
            <div class="feature-card">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#d8b4fe" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                <h3>Seguridad Total</h3>
                <p>Cifrado de grado militar y protección física para tu tranquilidad absoluta.</p>
            </div>

            <div class="feature-card">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#fca5a5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                </svg>
                <h3>Calidad Premium</h3>
                <p>Seleccionamos meticulosamente cada componente para un rendimiento óptimo.</p>
            </div>
        </div>
    </section>

    <div class="bottom-section">
        <div class="brands">
            <span class="brand-name">NVIDIA</span>
            <span class="brand-name">MICROSOFT</span>
            <span class="brand-name">INTEL</span>
            <span class="brand-name">AWS</span>
            <span class="brand-name">AMD</span>
        </div>

        <div class="why-techrm">
            <div class="why-content">
                <div class="section-subtitle">POR QUÉ TECHRM</div>
                <h2>Un Socio de Alto Nivel para Misiones Visionarias.</h2>
                <p>TechRM no es solo un proveedor de servicios; somos arquitectos de su infraestructura digital y física. Fusionamos la fiabilidad táctil del hardware con el potencial ilimitado del software.</p>
            </div>
            
            <div class="stats-grid">
                <div class="stat-box">
                    <div class="stat-value">Arquitectura</div>
                    <div class="stat-label">ESCALABLE</div>
                </div>
                <div class="stat-box">
                    <div class="stat-value">Enfoque</div>
                    <div class="stat-label">A MEDIDA</div>
                </div>
                <div class="stat-box">
                    <div class="stat-value">99.9%</div>
                    <div class="stat-label">DISPONIBILIDAD</div>
                </div>
                <div class="stat-box">
                    <div class="stat-value">24/7</div>
                    <div class="stat-label">SOPORTE</div>
                </div>
            </div>
        </div>
    </div>

    <footer>
        <div class="footer-left">
            <strong>TechRM</strong>
            <span>© 2026 TECHRM. PRECISIÓN EN INGENIERÍA.</span>
        </div>
        <div class="footer-links">
            <a href="#">POLÍTICA DE PRIVACIDAD</a>
            <a href="#">TÉRMINOS DE SERVICIO</a>
            <a href="#">ESPECIFICACIONES</a>
            <a href="#">API DOCS</a>
        </div>
        <div class="footer-social">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect><path d="M2 4l10 8 10-8"></path></svg>
        </div>
    </footer>

</body>
</html>
