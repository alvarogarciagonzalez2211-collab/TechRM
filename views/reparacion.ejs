<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reparación y Mantenimiento | TechRM</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        /* Variables Globales y Modos */
        :root {
            --bg-color: #0b0c10;
            --card-bg: #15161d;
            --card-inner: #1c1d26;
            --card-border: #262835;
            --text-main: #ffffff;
            --text-muted: #8b8e9f;
            --accent-blue: #93c5fd;
            --accent-red: #fca5a5; /* Color para mantenimientos/alertas */
            --nav-bg: rgba(11, 12, 16, 0.2);
            --nav-border: rgba(255, 255, 255, 0.05);
        }

        .light-mode {
            --bg-color: #ffffff;
            --card-bg: #f3f4f6;
            --card-inner: #ffffff;
            --card-border: rgba(0, 0, 0, 0.1);
            --text-main: #111827;
            --text-muted: #1f2937;
            --accent-blue: #1d4ed8;
            --accent-red: #dc2626;
            --nav-bg: rgba(255, 255, 255, 0.2);
            --nav-border: rgba(0, 0, 0, 0.05);
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            margin: 0;
            transition: background-color 0.3s, color 0.3s;
        }

        /* Navegación Glassmorphism */
        nav {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            background-color: var(--nav-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--nav-border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 4rem;
            box-sizing: border-box;
        }

        .logo { font-weight: 800; font-size: 1.5rem; }

        /* Estructura de la Vista */
        .repair-view {
            padding: 140px 4rem 6rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        .section-header { text-align: center; margin-bottom: 4rem; }
        .section-subtitle { 
            color: var(--accent-blue); 
            text-transform: uppercase; 
            font-weight: 700; 
            letter-spacing: 1.5px; 
            font-size: 0.8rem;
        }
        .section-title { font-size: 3rem; margin: 0.5rem 0; }
        .description { color: var(--text-muted); max-width: 600px; margin: 0 auto; }

        .container {
            display: grid;
            grid-template-columns: 1fr 350px;
            gap: 3rem;
        }

        /* Formulario */
        .repair-form {
            background: var(--card-bg);
            padding: 3rem;
            border-radius: 16px;
            border: 1px solid var(--card-border);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .form-group { margin-bottom: 2rem; }
        .form-group label { 
            display: block; 
            margin-bottom: 0.8rem; 
            font-weight: 600; 
            font-size: 0.9rem;
        }

        .form-grid { 
            display: grid; 
            grid-template-columns: 1fr 1fr; 
            gap: 2rem; 
        }

        input, select, textarea {
            width: 100%;
            padding: 1rem;
            background: var(--card-inner);
            border: 1px solid var(--card-border);
            border-radius: 8px;
            color: var(--text-main);
            font-family: inherit;
            box-sizing: border-box;
        }

        /* Selector de Urgencia */
        .urgency-selector {
            display: flex;
            gap: 1rem;
        }
        .urgency-selector input { display: none; }
        .urgency-card {
            flex: 1;
            background: var(--card-inner);
            border: 2px solid var(--card-border);
            padding: 1rem;
            border-radius: 8px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 0.85rem;
            font-weight: 600;
        }
        #urgent:checked + .urgency-card {
            border-color: var(--accent-red);
            background: rgba(252, 165, 165, 0.1);
        }
        #normal:checked + .urgency-card {
            border-color: var(--accent-blue);
            background: rgba(147, 197, 253, 0.1);
        }

        .btn-submit {
            width: 100%;
            padding: 1.2rem;
            background: var(--accent-blue);
            color: #1e3a8a;
            border: none;
            border-radius: 8px;
            font-weight: 700;
            text-transform: uppercase;
            cursor: pointer;
            transition: transform 0.2s;
            margin-top: 1rem;
        }
        .btn-submit:hover { transform: translateY(-3px); }

        /* Lateral Informativo */
        .info-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            padding: 2.5rem;
            border-radius: 16px;
            height: fit-content;
            position: sticky;
            top: 140px;
        }

        .info-card h4 { color: var(--accent-blue); margin-bottom: 1.5rem; }
        .info-card ul { list-style: none; padding: 0; }
        .info-card li { 
            display: flex; 
            gap: 1rem; 
            margin-bottom: 1.5rem; 
            font-size: 0.9rem; 
            color: var(--text-muted);
        }
        .info-card .icon {
            color: var(--accent-blue);
            font-weight: 800;
        }

        @media (max-width: 900px) {
            .container { grid-template-columns: 1fr; }
            .repair-view { padding: 120px 2rem; }
            .form-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <nav hidden style="display: none;">
        <div class="logo">TechRM</div>
        <div style="display: flex; gap: 20px; align-items: center;">
            <a href="/" style="color: inherit; text-decoration: none; font-size: 0.9rem;">Inicio</a>
            <a href="/montaje" style="color: inherit; text-decoration: none; font-size: 0.9rem;">Montaje</a>
            <button id="legacy-theme-toggle" style="background: none; border: 1px solid var(--card-border); color: var(--text-main); padding: 5px 10px; cursor: pointer; border-radius: 5px;">
                🌓
            </button>
        </div>
    </nav>

    <%- include('navbar') %>

    <main class="repair-view">
        <div class="section-header">
            <span class="section-subtitle">Soporte Técnico Avanzado</span>
            <h1 class="section-title">Devolvemos la vida a tu hardware</h1>
            <p class="description">Diagnóstico preciso y soluciones duraderas para cualquier tipo de avería técnica o mantenimiento preventivo.</p>
        </div>

        <div class="container">
            <form class="repair-form" action="/solicitar-reparacion" method="POST">
                
                <div class="form-grid">
                    <div class="form-group">
                        <label for="dispositivo">Marca y Modelo</label>
                        <input type="text" id="dispositivo" name="dispositivo" placeholder="Ej: MacBook Pro M1 / PC Gaming Custom" required>
                    </div>
                    <div class="form-group">
                        <label for="servicio">Tipo de Servicio</label>
                        <select id="servicio" name="servicio">
                            <option value="reparacion">Reparación de Avería</option>
                            <option value="mantenimiento">Mantenimiento / Limpieza</option>
                            <option value="software">Optimización de Software</option>
                            <option value="recuperacion">Recuperación de Datos</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Nivel de Urgencia</label>
                    <div class="urgency-selector">
                        <input type="radio" name="urgencia" id="normal" value="normal" checked>
                        <label for="normal" class="urgency-card">Estándar (3-5 días)</label>

                        <input type="radio" name="urgencia" id="urgent" value="urgente">
                        <label for="urgent" class="urgency-card">Express (24-48h)</label>
                    </div>
                </div>

                <div class="form-group">
                    <label for="descripcion">Descripción del problema</label>
                    <textarea id="descripcion" name="descripcion" rows="5" placeholder="Describe los síntomas: ruidos extraños, no enciende, pantallazos azules..."></textarea>
                </div>

                <button type="submit" class="btn-submit">Solicitar Diagnóstico</button>
            </form>

            <aside>
                <div class="info-card">
                    <h4>Nuestro Proceso</h4>
                    <ul>
                        <li>
                            <span class="icon">✓</span>
                            <div><strong>Recepción:</strong> Registro fotográfico del estado inicial del equipo.</div>
                        </li>
                        <li>
                            <span class="icon">✓</span>
                            <div><strong>Diagnóstico:</strong> Informe técnico detallado en menos de 24h.</div>
                        </li>
                        <li>
                            <span class="icon">✓</span>
                            <div><strong>Reparación:</strong> Uso exclusivo de componentes originales o certificados.</div>
                        </li>
                        <li>
                            <span class="icon">✓</span>
                            <div><strong>Control:</strong> Pruebas finales de rendimiento y temperatura.</div>
                        </li>
                    </ul>
                </div>
            </aside>
        </div>
    </main>

    <script>
        const themeToggle = document.getElementById('legacy-theme-toggle');
        const body = document.body;

        if (localStorage.getItem('theme') === 'light') {
            body.classList.add('light-mode');
        }

        themeToggle.addEventListener('click', () => {
            body.classList.toggle('light-mode');
            const theme = body.classList.contains('light-mode') ? 'light' : 'dark';
            localStorage.setItem('theme', theme);
        });
    </script>
</body>
</html>
