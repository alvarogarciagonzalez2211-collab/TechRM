<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= service.title %> | TechRM</title>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        :root {
            --bg-color: #0b0c12;
            --bg-panel: #11131a;
            --card-bg: #171923;
            --card-border: rgba(255, 255, 255, 0.1);
            --text-main: #ffffff;
            --text-muted: #9ca3af;
            --accent-main: <%= service.accent %>;
            --accent-soft: <%= service.accentSoft %>;
            --accent-alt: <%= service.accentAlt %>;
            --accent-text: <%= service.accentText %>;
            --nav-bg: rgba(11, 12, 16, 0.95);
            --nav-border: rgba(255, 255, 255, 0.05);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--bg-color);
            color: var(--text-main);
            font-family: 'Inter', system-ui, sans-serif;
            line-height: 1.6;
            min-height: 100vh;
        }

        .software-detail-hero {
            min-height: 640px;
            display: grid;
            grid-template-columns: minmax(0, 0.95fr) minmax(360px, 1.05fr);
            align-items: center;
            gap: 4rem;
            padding: 9rem 6% 5rem;
            background:
                linear-gradient(90deg, rgba(11, 12, 18, 0.98), rgba(11, 12, 18, 0.78)),
                url('<%= service.heroImage %>') center/cover;
            border-bottom: 1px solid var(--card-border);
        }

        .hero-copy { max-width: 720px; }

        .eyebrow {
            color: var(--accent-main);
            font-size: 0.78rem;
            font-weight: 900;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin-bottom: 1.4rem;
        }

        .software-detail-hero h1 {
            font-size: clamp(2.8rem, 6vw, 5.3rem);
            line-height: 0.98;
            margin-bottom: 1.5rem;
        }

        .software-detail-hero h1 span { color: var(--accent-main); }

        .hero-copy p {
            color: var(--text-muted);
            max-width: 620px;
            font-size: 1.08rem;
            margin-bottom: 2rem;
        }

        .hero-actions {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .btn-service {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 46px;
            padding: 0.85rem 1.35rem;
            background: transparent;
            border: 1px solid var(--card-border);
            color: var(--text-main);
            border-radius: 8px;
            font-size: 0.78rem;
            font-weight: 900;
            letter-spacing: 0.4px;
            text-transform: uppercase;
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.2s, border-color 0.2s, background 0.2s;
        }

        .btn-service:hover,
        .btn-service:focus {
            transform: translateY(-2px);
            border-color: var(--accent-soft);
            background: rgba(255, 255, 255, 0.06);
        }

        .btn-primary-service {
            background: var(--accent-main);
            color: var(--accent-text);
            border-color: transparent;
        }

        .lead-form {
            align-self: center;
            border: 1px solid var(--accent-soft);
            border-radius: 8px;
            background: rgba(17, 19, 26, 0.9);
            padding: 1.5rem;
            box-shadow: 0 22px 70px rgba(0, 0, 0, 0.28);
            backdrop-filter: blur(14px);
        }

        .lead-form h2 {
            font-size: 1.45rem;
            line-height: 1.15;
            margin-bottom: 0.55rem;
        }

        .lead-form p {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 1.1rem;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.8rem;
        }

        .form-group { margin-bottom: 0.85rem; }

        .form-group label {
            display: block;
            color: #dce7f5;
            font-size: 0.7rem;
            font-weight: 900;
            margin-bottom: 0.4rem;
            text-transform: uppercase;
        }

        input,
        select,
        textarea {
            width: 100%;
            border: 1px solid var(--card-border);
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.06);
            color: var(--text-main);
            font-family: inherit;
            padding: 0.82rem 0.9rem;
        }

        textarea { resize: vertical; }

        .form-submit {
            width: 100%;
            min-height: 46px;
            margin-top: 0.25rem;
            border: none;
            border-radius: 8px;
            background: var(--accent-main);
            color: var(--accent-text);
            cursor: pointer;
            font-weight: 900;
            text-transform: uppercase;
        }

        .success-banner {
            margin-bottom: 1rem;
            padding: 0.8rem 0.9rem;
            border: 1px solid rgba(134, 239, 172, 0.45);
            border-radius: 8px;
            background: rgba(134, 239, 172, 0.12);
            color: #bff7d2;
            font-size: 0.86rem;
            font-weight: 800;
        }

        .container {
            max-width: 1180px;
            margin: 0 auto;
            padding: 4rem 2rem;
        }

        .section-heading {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 2rem;
            margin-bottom: 1.5rem;
        }

        .section-heading h2 {
            font-size: clamp(1.9rem, 4vw, 2.8rem);
            line-height: 1.05;
        }

        .section-heading p {
            color: var(--text-muted);
            max-width: 460px;
            font-size: 0.95rem;
        }

        .feature-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1.25rem;
        }

        .feature-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 8px;
            padding: 1.35rem;
        }

        .feature-tag {
            display: inline-flex;
            margin-bottom: 1rem;
            padding: 0.25rem 0.65rem;
            border-radius: 999px;
            background: var(--accent-main);
            color: var(--accent-text);
            font-size: 0.68rem;
            font-weight: 900;
            text-transform: uppercase;
        }

        .feature-tag.alt { background: var(--accent-alt); color: #0b0c12; }

        .feature-card h3 {
            font-size: 1.18rem;
            line-height: 1.2;
            margin-bottom: 0.7rem;
        }

        .feature-card p {
            color: var(--text-muted);
            font-size: 0.88rem;
        }

        .split-section {
            margin-top: 4rem;
            display: grid;
            grid-template-columns: 0.9fr 1.1fr;
            gap: 2rem;
            align-items: stretch;
        }

        .detail-image {
            min-height: 430px;
            border: 1px solid var(--card-border);
            border-radius: 8px;
            background:
                linear-gradient(180deg, rgba(11, 12, 18, 0.12), rgba(11, 12, 18, 0.72)),
                url('<%= service.detailImage %>') center/cover;
        }

        .step-list { display: grid; gap: 1rem; }

        .step-item {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 1rem;
            background: var(--bg-panel);
            border: 1px solid var(--card-border);
            border-radius: 8px;
            padding: 1.25rem;
        }

        .step-item strong {
            width: 34px;
            height: 34px;
            display: grid;
            place-items: center;
            border-radius: 50%;
            background: var(--accent-main);
            color: var(--accent-text);
        }

        .step-item h3 {
            font-size: 1rem;
            margin-bottom: 0.35rem;
        }

        .step-item p {
            color: var(--text-muted);
            font-size: 0.86rem;
        }

        .cta-panel {
            margin-top: 4rem;
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 2rem;
            align-items: center;
            padding: 2rem;
            background: linear-gradient(160deg, var(--accent-soft), var(--bg-panel));
            border: 1px solid var(--card-border);
            border-radius: 8px;
        }

        .cta-panel h2 {
            font-size: 2rem;
            line-height: 1.1;
            margin-bottom: 0.8rem;
        }

        .cta-panel p {
            color: var(--text-muted);
            max-width: 720px;
        }

        footer {
            padding: 3rem 6%;
            border-top: 1px solid var(--card-border);
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            font-size: 0.72rem;
            color: var(--text-muted);
            text-transform: uppercase;
            font-weight: 700;
        }

        .light-mode {
            --bg-color: #f7f9fc;
            --bg-panel: #ffffff;
            --card-bg: #f8f9fa;
            --card-border: rgba(23, 32, 51, 0.12);
            --text-main: #172033;
            --text-muted: #4b5565;
            --nav-bg: rgba(248, 249, 250, 0.95);
            --nav-border: rgba(0, 0, 0, 0.05);
        }

        .light-mode .software-detail-hero {
            background:
                linear-gradient(90deg, rgba(247, 249, 252, 0.98), rgba(247, 249, 252, 0.86)),
                url('<%= service.heroImage %>') center/cover;
        }

        .light-mode .lead-form { background: rgba(255, 255, 255, 0.92); }

        .light-mode input,
        .light-mode select,
        .light-mode textarea {
            background: #ffffff;
            color: var(--text-main);
            border-color: rgba(23, 32, 51, 0.14);
        }

        .light-mode .detail-image {
            background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0.32)),
                url('<%= service.detailImage %>') center/cover;
            filter: saturate(1.04) contrast(1.02) brightness(1.03);
        }

        .light-mode .cta-panel { background: linear-gradient(160deg, var(--accent-soft), #ffffff); }

        .light-mode .success-banner {
            background: rgba(21, 128, 61, 0.1);
            border-color: rgba(21, 128, 61, 0.24);
            color: #166534;
        }

        .light-mode .nav-links a.active {
            color: var(--accent-main);
            border-bottom-color: var(--accent-main);
        }

        @media (max-width: 980px) {
            .software-detail-hero,
            .split-section,
            .cta-panel { grid-template-columns: 1fr; }

            .feature-grid { grid-template-columns: 1fr 1fr; }
            .lead-form { align-self: auto; }
            .detail-image { min-height: 320px; }
        }

        @media (max-width: 720px) {
            .software-detail-hero {
                padding: 8rem 1.25rem 3rem;
                gap: 2rem;
            }

            .feature-grid,
            .form-row { grid-template-columns: 1fr; }
            .section-heading { display: block; }
            .section-heading p { margin-top: 1rem; }
            .container { padding: 3rem 1.25rem; }
            footer { flex-direction: column; }
        }
    </style>
</head>
<body>

    <%- include('navbar') %>

    <header class="software-detail-hero">
        <div class="hero-copy">
            <div class="eyebrow"><%= service.eyebrow %></div>
            <h1><%- service.heading %></h1>
            <p><%= service.description %></p>
            <div class="hero-actions">
                <a class="btn-service btn-primary-service" href="#solicitud">Pedir propuesta</a>
                <a class="btn-service" href="/software">Volver a software</a>
            </div>
        </div>

        <form class="lead-form" id="solicitud" action="<%= service.formAction %>" method="POST">
            <h2><%= service.formTitle %></h2>
            <p><%= service.formIntro %></p>
            <% if (typeof success !== 'undefined' && success) { %>
                <div class="success-banner">Solicitud enviada. Te responderemos lo antes posible.</div>
            <% } %>
            <div class="form-row">
                <div class="form-group">
                    <label for="nombre">Nombre</label>
                    <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required>
                </div>
                <div class="form-group">
                    <label for="contacto">Contacto</label>
                    <input type="text" id="contacto" name="contacto" placeholder="Email o telefono" required>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="tipo">Tipo de negocio</label>
                    <input type="text" id="tipo" name="tipo" placeholder="Tienda, taller, clinica...">
                </div>
                <div class="form-group">
                    <label for="plazo">Plazo ideal</label>
                    <select id="plazo" name="plazo">
                        <option>Sin prisa</option>
                        <option>1-2 meses</option>
                        <option>Lo antes posible</option>
                        <option>No estoy seguro</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label for="detalles"><%= service.formQuestion %></label>
                <textarea id="detalles" name="detalles" rows="3" placeholder="<%= service.formPlaceholder %>"></textarea>
            </div>
            <button class="form-submit" type="submit">Solicitar propuesta</button>
        </form>
    </header>

    <main class="container">
        <section>
            <div class="section-heading">
                <h2><%= service.featuresTitle %></h2>
                <p><%= service.featuresIntro %></p>
            </div>

            <div class="feature-grid">
                <% service.features.forEach(function(feature, index) { %>
                    <article class="feature-card">
                        <span class="feature-tag <%= index === 1 ? 'alt' : '' %>"><%= feature.tag %></span>
                        <h3><%= feature.title %></h3>
                        <p><%= feature.text %></p>
                    </article>
                <% }) %>
            </div>
        </section>

        <section class="split-section">
            <div class="detail-image" aria-label="<%= service.imageLabel %>"></div>
            <div class="step-list">
                <% service.steps.forEach(function(step, index) { %>
                    <article class="step-item">
                        <strong><%= index + 1 %></strong>
                        <div>
                            <h3><%= step.title %></h3>
                            <p><%= step.text %></p>
                        </div>
                    </article>
                <% }) %>
            </div>
        </section>

        <section class="cta-panel">
            <div>
                <h2><%= service.ctaTitle %></h2>
                <p><%= service.ctaText %></p>
            </div>
            <a class="btn-service btn-primary-service" href="/software">Ver todos</a>
        </section>
    </main>

    <footer>
        <div class="logo">TECHRM</div>
        <div>© 2026 TECHRM. <%= service.footer %></div>
    </footer>

</body>
</html>
