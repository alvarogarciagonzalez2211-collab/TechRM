<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechRM - Innovación en Software</title>
    <style>
        :root {
            --bg-dark: #0b0c12;
            --card-bg: #16171f;
            --accent-purple: #8b5cf6;
            --accent-purple-dark: #7c3aed;
            --text-main: #ffffff;
            --text-muted: #8b8e9f;
            --border-color: rgba(255, 255, 255, 0.08);
            --nav-bg: rgba(11, 12, 16, 0.95);
            --nav-border: rgba(255,255,255,0.05);
        }

        .light-mode {
            --bg-dark: #ffffff;
            --card-bg: #f8f9fa;
            --accent-purple: #6f42c1;
            --accent-purple-dark: #5a32a3;
            --text-main: #212529;
            --text-muted: #6c757d;
            --border-color: rgba(0, 0, 0, 0.1);
            --nav-bg: rgba(248, 249, 250, 0.95);
            --nav-border: rgba(0,0,0,0.05);
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Inter', -apple-system, sans-serif;
            margin: 0;
            line-height: 1.6;
            min-height: 100vh;
        }

        /* Hero Software */
        .hero-software {
            text-align: center;
            padding: 8rem 2rem 6rem;
            background: radial-gradient(circle at top, rgba(139, 92, 246, 0.15) 0%, transparent 50%);
        }

        .badge-software {
            display: inline-block;
            border: 1px solid var(--accent-purple);
            padding: 0.3rem 1.2rem;
            border-radius: 20px;
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--text-main);
            margin-bottom: 2rem;
        }

        .hero-software h1 {
            font-size: clamp(2.5rem, 5vw, 4rem);
            margin-bottom: 1.5rem;
            font-weight: 800;
        }

        .hero-software h1 span { color: var(--accent-purple); }

        .hero-software p {
            color: var(--text-muted);
            max-width: 700px;
            margin: 0 auto 3rem;
            font-size: 1.05rem;
        }

        .hero-buttons {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
        }

        .btn-primary {
            background: var(--accent-purple);
            color: white;
            padding: 1rem 2.5rem;
            border-radius: 6px;
            font-weight: 700;
            text-transform: uppercase;
            border: none;
            font-size: 0.8rem;
            cursor: pointer;
        }

        .btn-secondary {
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 1rem 2.5rem;
            border-radius: 6px;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.8rem;
            cursor: pointer;
        }

        /* Services Section */
        .section-container { max-width: 1200px; margin: 0 auto; padding: 4rem 2rem; }

        .section-title-line {
            font-size: 2rem;
            margin-bottom: 3rem;
            border-bottom: 3px solid var(--accent-purple);
            display: inline-block;
            padding-bottom: 10px;
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .service-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            padding: 3rem 2.5rem;
            border-radius: 12px;
            transition: transform 0.3s ease;
        }

        .service-card:hover { transform: translateY(-5px); }

        .service-card svg { margin-bottom: 1.5rem; color: var(--accent-purple); }

        .service-card h3 { margin-bottom: 1rem; font-size: 1.4rem; }

        .service-card p { color: var(--text-muted); font-size: 0.9rem; }

        /* Proceso ¿Cómo empezamos? */
        .process-section {
            text-align: center;
            padding: 6rem 2rem;
        }

        .process-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 3rem;
            margin-top: 4rem;
        }

        .process-step .step-num {
            width: 45px; height: 45px;
            background: var(--accent-purple);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-weight: 800;
        }

        .process-step h4 { margin-bottom: 1rem; font-size: 1.2rem; }
        .process-step p { color: var(--text-muted); font-size: 0.85rem; }

        /* Contact Box */
        .contact-box {
            background: #111218;
            border: 1px solid var(--border-color);
            border-radius: 16px;
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            overflow: hidden;
            margin-top: 4rem;
        }

        .contact-info { padding: 4rem; border-right: 1px solid var(--border-color); }
        .contact-form { padding: 4rem; background: rgba(255,255,255,0.02); }

        .contact-info h2 { font-size: 2.5rem; margin-bottom: 2rem; }
        
        .trust-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .form-group { margin-bottom: 2rem; }
        .form-group label {
            display: block;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            margin-bottom: 0.8rem;
            color: var(--text-muted);
        }

        .form-group input, .form-group select, .form-group textarea {
            width: 100%;
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border-color);
            padding: 1rem;
            border-radius: 6px;
            color: white;
            font-family: inherit;
        }
        .form-group select{
            color: rgb(80, 79, 79);
            
        }


       
        .btn-submit-full {
            width: 100%;
            background: var(--accent-purple);
            color: white;
            padding: 1.2rem;
            border-radius: 8px;
            font-weight: 800;
            text-transform: uppercase;
            border: none;
            cursor: pointer;
            font-size: 0.85rem;
        }

        /* Footer */
        footer {
            padding: 4rem 6%;
            border-top: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            font-size: 0.65rem;
            color: var(--text-muted);
        }

        /* Light Mode Overrides */
        .light-mode nav {
            background: var(--nav-bg);
        }

        .light-mode .nav-links a.active {
            color: #6f42c1;
            border-bottom: 2px solid #6f42c1;
        }

        .light-mode .btn-toggle {
            border: 1px solid rgba(0,0,0,0.2);
        }

        .light-mode .btn-toggle:hover {
            background: rgba(0,0,0,0.1);
            border-color: rgba(0,0,0,0.4);
        }

        .light-mode footer {
            border-top: 1px solid rgba(0, 0, 0, 0.1);
        }

        @media (max-width: 900px) {
            .contact-box { grid-template-columns: 1fr; }
            .contact-info { border-right: none; border-bottom: 1px solid var(--border-color); padding: 2rem; }
            .contact-form { padding: 2rem; }
            .hero-buttons { flex-direction: column; }
        }
    </style>
</head>
<body>

    <%- include('navbar') %>

    <header class="hero-software">
        <span class="badge-software">Ecosistema Digital</span>
        <h1>Innovación en <span>Software</span></h1>
        <p>Desarrollamos soluciones digitales a medida que transforman la complejidad técnica en una ventaja competitiva para su negocio. Ingeniería de software con precisión táctil.</p>
        <div class="hero-buttons">
            <button class="btn-primary" onclick="document.querySelector('.contact-box').scrollIntoView({ behavior: 'smooth' })">CONSULTAR PROYECTO</button>
            <button class="btn-secondary" onclick="document.querySelector('.section-container').scrollIntoView({ behavior: 'smooth' })">VER CATÁLOGO</button>
        </div>
    </header>

    <div class="section-container">
        <h2 class="section-title-line">Servicios de Ingeniería</h2>
        
        <div class="services-grid">
            <div class="service-card">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h18v18H3zM3 9h18M9 21V9"/></svg>
                <h3>Gestión de Negocio</h3>
                <p>Herramientas sencillas para organizar sus ventas, clientes y stock en un solo lugar. Ideal para pequeñas y medianas empresas que buscan digitalizarse.</p>
            </div>
            <div class="service-card">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                <h3>Sistemas de Venta</h3>
                <p>Cajas registradoras modernas y fáciles de usar que se conectan con su inventario automáticamente para evitar errores.</p>
            </div>
            <div class="service-card">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                <h3>Páginas Web</h3>
                <p>Creamos su presencia en Internet con diseños atractivos que cargan rápido y funcionan perfectamente en cualquier teléfono móvil.</p>
            </div>
            <div class="service-card">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                <h3>Soporte y Mejora</h3>
                <p>Actualizamos y mejoramos sus programas actuales para que funcionen más rápido y sin fallos técnicos molestos.</p>
            </div>
        </div>

        <div class="process-section">
            <h2 style="font-size: 2.2rem;">¿Cómo empezamos?</h2>
            <p style="color: var(--text-muted);">Tres pasos simples para transformar su idea en realidad</p>
            
            <div class="process-grid">
                <div class="process-step">
                    <div class="step-num">1</div>
                    <h4>Consulta Gratis</h4>
                    <p>Hablamos sobre sus necesidades y le asesoramos sobre la mejor solución sin compromiso.</p>
                </div>
                <div class="process-step">
                    <div class="step-num">2</div>
                    <h4>Diseño a Medida</h4>
                    <p>Creamos un plan detallado y visual de cómo funcionará su nuevo sistema paso a paso.</p>
                </div>
                <div class="process-step">
                    <div class="step-num">3</div>
                    <h4>Lanzamiento</h4>
                    <p>Instalamos todo y formamos a su equipo para que empiecen a trabajar con total confianza.</p>
                </div>
            </div>
        </div>

        <section class="contact-box">
            <div class="contact-info">
                <h2>¿Listo para dar el paso?</h2>
                <p style="color: var(--text-muted); margin-bottom: 2.5rem;">Estamos aquí para simplificar la tecnología para usted. Complete el formulario y nos pondremos en contacto hoy mismo para ayudarle.</p>
                
                <div class="trust-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                    <span>Le llamamos en menos de 24 horas</span>
                </div>
                <div class="trust-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                    <span>Sin términos técnicos confusos</span>
                </div>
            </div>
            
            <div class="contact-form">
                <form>
                    <div class="form-group">
                        <label>MI NOMBRE</label>
                        <input type="text" placeholder="Juan Pérez">
                    </div>
                    <div class="form-group" style="display: flex; gap: 1rem; margin-bottom: 2rem;  ">
                        <div style="flex: 1; margin-right: 1rem;">
                            <label>MI TELÉFONO</label>
                            <input type="text" placeholder="+34 600 123 456">
                        </div>
                        <div style="flex: 1; margin-left: 1rem;">
                            <label>MI CORREO</label>
                            <input type="email" placeholder="juan.perez@email.com">
                        </div>
                    </div>
                    <div class="form-group">
                        <label>¿QUÉ NECESITA?</label>
                        <select>
                            <option value="">Seleccione una opción</option>
                            <option value="programa">Necesito un programa para mi negocio</option>
                            <option value="pagina">Necesito una página web</option>
                            <option value="soporte">Necesito soporte técnico</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>CUÉNTENOS MÁS (OPCIONAL)</label>
                        <textarea rows="4" placeholder="¿En qué podemos ayudarle hoy?"></textarea>
                    </div>
                    <button type="button" class="btn-submit-full">SOLICITAR INFORMACIÓN GRATUITA</button>
                </form>
            </div>
        </section>
    </div>

    <footer>
        <div class="logo">TechRM</div>
    
        <div>© 2026 TECHRM. ENGINEERED PRECISION.</div>
    </footer>

</body>
</html>